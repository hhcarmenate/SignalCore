# Root environment map for SignalCore

COMPOSE_PROJECT_NAME=signalcore

# Shared defaults
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=America/New_York

# Database
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=signalcore
DB_USERNAME=signalcore
DB_PASSWORD=signalcore

# API
API_PORT=8000

# Web
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api

# Scanner
SCANNER_ENV=local
MARKET_DATA_PROVIDER=twelve_data

# Provider keys
TWELVE_DATA_API_KEY=
